<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingLeft="20dp"
        android:paddingTop="24dp"
        android:paddingRight="20dp"
        android:paddingBottom="120dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            style="@style/TextAppearance.FLYU.Display" />

        <com.yuuki.flyu.ui.widget.DynamicSubtitleView
            android:id="@+id/home_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:textColor="#6070CC" />

        <!-- 状态卡片 -->
        <com.yuuki.flyu.ui.widget.LinearLayoutPro
            android:id="@+id/card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:padding="0dp" />

        <!-- 设备信息卡片 -->
        <com.yuuki.flyu.ui.widget.LinearLayoutPro
            android:id="@+id/card_device_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="0dp" />

        <!-- 作者信息卡片 -->
        <com.yuuki.flyu.ui.widget.LinearLayoutPro
            android:id="@+id/card_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="0dp" />

        <!-- 特别鸣谢卡片 -->
        <com.yuuki.flyu.ui.widget.LinearLayoutPro
            android:id="@+id/card_thanks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:padding="0dp" />

    </LinearLayout>

</ScrollView>
